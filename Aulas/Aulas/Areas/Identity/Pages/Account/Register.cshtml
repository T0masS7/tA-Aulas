﻿
@page
@model RegisterModel
@{
   ViewData["Title"] = "Registar";
}

<h1>@ViewData["Title"]</h1>

<form id="registerForm" asp-route-returnUrl="@Model.ReturnUrl" method="post">
  
   <h2>Criar uma nova conta.</h2>
   <hr />
   <div asp-validation-summary="ModelOnly" class="text-danger" role="alert"></div>
   
   <div class="row">
      <div class="col-md-4">
         <div class="form-floating mb-3">
            <input asp-for="Input.Email" class="form-control" autocomplete="username" aria-required="true" placeholder="name@example.com" />
            <label asp-for="Input.Email">Email</label>
            <span asp-validation-for="Input.Email" class="text-danger"></span>
         </div>
         <div class="form-floating mb-3">
            <input asp-for="Input.Password" class="form-control" autocomplete="new-password" aria-required="true" placeholder="password" />
            <label asp-for="Input.Password">Password</label>
            <span asp-validation-for="Input.Password" class="text-danger"></span>
         </div>
         <div class="form-floating mb-3">
            <input asp-for="Input.ConfirmPassword" class="form-control" autocomplete="new-password" aria-required="true" placeholder="password" />
            <label asp-for="Input.ConfirmPassword">Confirm Password</label>
            <span asp-validation-for="Input.ConfirmPassword" class="text-danger"></span>
         </div>
            
      </div>
      <div class="col-md-6">
         <div class="form-floating mb-3">
            <input asp-for="Input.Student.Name" class="form-control" autocomplete="username" aria-required="true" />
            <label asp-for="Input.Student.Name"></label>
            <span asp-validation-for="Input.Student.Name" class="text-danger"></span>
         </div>
         <div class="form-floating mb-3">
            <input asp-for="Input.Student.BirthDate" class="form-control" autocomplete="username" aria-required="true"  />
            <label asp-for="Input.Student.BirthDate"></label>
            <span asp-validation-for="Input.Student.BirthDate" class="text-danger"></span>
         </div>
         <div class="form-floating mb-3">
            <input asp-for="Input.Student.CellPhone" class="form-control" autocomplete="username" aria-required="true"  />
            <label asp-for="Input.Student.CellPhone"></label>
            <span asp-validation-for="Input.Student.CellPhone" class="text-danger"></span>
         </div>
         <div class="form-floating mb-3">
            <input asp-for="Input.Student.TuitionFeeAux" class="form-control" autocomplete="username" aria-required="true"  />
            <label asp-for="Input.Student.TuitionFeeAux"></label>
            <span asp-validation-for="Input.Student.TuitionFeeAux" class="text-danger"></span>
         </div>
         <div class="form-group">
            <label asp-for="Input.Student.DegreeFK" class="control-label"></label>
            <select asp-for="Input.Student.DegreeFK" class="form-control" asp-items="ViewBag.DegreeFK">
               <option value="">-- Selecione Curso --</option>
            </select>
         </div>
      </div>
   </div>
   <div class="row">
      <div class="col-md-4">
         <button id="registerSubmit" type="submit" class="w-100 btn btn-lg btn-primary">Criar conta</button>
      </div>
   </div>

</form>

@section Scripts {
      <partial name="_ValidationScriptsPartial" />
   }